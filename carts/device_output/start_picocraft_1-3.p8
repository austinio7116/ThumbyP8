--particles and easing fn
function updatepart()
  for p in all(parts) do
    p.t += 1
    if p.t > p.tmax then
      del(parts, p)
    end
    p:update()
  end
end

function drawpart()
  for p in all(parts) do
    p:draw()
  end
end

function add_ash_part()
  local newpart = {x = 16 + rnd(96), y = 128, amp = 4 + rnd(2), tet = rnd(1), t = 0, tmax = 150, col = 1 + rnd(4) // 1, update = update_ash, draw = draw_ash}
  add(parts, newpart)
end

function update_ash(self)
  self.y -= 1
  self.tet = self.tet % 1 + 0.01
end

function draw_ash(self)
  local c = mid(0, self.col - self.y // 32, 3)
  pal(dark_pal[c])
  palt(0x8000)
  local bx, sx, fx, amp = cos(self.tet), 112, false, self.amp * (self.y / 64)
  if abs(bx) < 0.75 then
    sx, fx = self.t // 2 % 2 == 0 and 112 or 116, self.tet >= 0.5
  end
  sspr(sx, 8, 4, 4, self.x + bx * amp, self.y, 4, 4, fx)
end

--easing fn
function lerp(v0, v1, prc)
  return (1 - prc) * v0 + prc * v1
end

function easeoutbounce(x)
  return abs(sin(x / 2 + 0.25)) * (1 - x)
end

