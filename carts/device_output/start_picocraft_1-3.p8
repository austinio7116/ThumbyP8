function _update()
  t += 1
  mx, my, mb, oldmx, oldmy = stat(32), stat(33), stat(34), mx, my
  mbtn1, mbtn2, mbtn1r = m_pressed(mb, 0x01), m_pressed(mb, 0x02)
  curscene:update()
  updatepart()
  --reinit m_pressed
  pmb = mb
end

-- mouse just pressed
function m_pressed(mb, n)
  return mb & n == n and pmb & n == 0
end

function mbclick()
  local x1, x2 = 29, 98
  for i = 1, 4 do
    local y1 = i * 20 + 26
    if y1 < my and my < y1 + 13 and x1 < mx and mx < x2 then
      return i
    end
  end
  return
end

function _draw()
  cls()
  drawpart()
  pal(dark_pal[ttlpalidx])
  palt(0x1000)
  curscene:draw()
-- ?"curscene "..curscene.name,0,0
-- ?"nextscn"..(nextscn and nextscn.name or "")
-- ?"hidescn "..(hidescn and 1 or 0)
-- ?"showscn "..(showscn and 1 or 0)
end

-- title scene
function updtitle()
  if (btn(5) or mbtn1) and t > 13 and not gotomnu then
    --trigger
    gotomnu, t = true, 0
  end
  if gotomnu then
    ease = (t - 60) / 60
    movepoints(ease)
    if t == 70 then
      sfx(5)
    end
    if t == 120 then
      curscene = menuscn
    end
  else
    if t % 3 == 0 then
      add_ash_part()
    end
  end
end

function drwtitle(self)
  y = self.y or 48
  if gotomnu then
    self.y = lerp(y, 6, 0.05)
    if t > 60 then
      camera(0, 128 * easeoutbounce((t - 60) / 60))
      drawbg()
      drawcols()
      drawbtns()
      camera()
    end
  else
    ttlpalidx = fadeinidx()
  end
  --vcenter title
  sspr(0, 0, 109, 31, 8, y)
  print("pixel @brullov_art", 0, 110, 1)
  print("code  @yourykiki")
  print("1.2")
end

function fadeinidx()
  return 4 - min(t, 40) // 3
end

function fadeoutidx()
  return min(t, 12) // 3
end

--menu scene
function updmenu()
  --anim transition
  if hidescn then
    ease = (30 - t) / 30
    movepoints(ease)
    if (t == 30) then
      --curscene=menuscn
      hidescn, showscn, t = false, true, 0
      if nextscn then
        curscene, nextscn = nextscn, nil
      else
        curmenu = nextmenu
      end
    end
  elseif showscn then
    ease = t / 30
    movepoints(ease)
    if t == 30 then
      showscn = false
    elseif t == 1 then
      sfx(3)
    end
  else
    dmnu = 0
    if btnp(2) then
      dmnu -= 1
    end
    if btnp(3) then
      dmnu += 1
    end
    selmnu = mid(1, dmnu + selmnu, 4)
    if mx ~= oldmx or my ~= oldmy then
      selmnu = mbclick() or selmnu
    end
    if btn(5) or mbtn1 and mbclick() then
      _ENV[curmenu[selmnu].action]()
      if selmnu != 2 then
        sfx(4)
      end
    end
    if (btn(4) or mbtn2) and curmenu ~= menu_main then
      nextmenu, hidescn, t = menu_main, true, 0
      sfx(4)
    end
  end
end

function drwmenu()
  if hidescn or showscn then
    camera(0, 128 * easeoutbounce(ease))
  end
  --chains
  drawbg()
  drawcols()
  drawbtns()
  if hidescn or showscn then
    camera()
  end
  --title
  sspr(0, 0, 109, 31, 8, 6)
  --mouse
  palt(0x1000)
  spr(14, mx, my)
end

function drawcols()
  palt(0x1000)
  drawcol(0)
  drawcol(108)
end

function drawbg()
  palt(0x1000)
  sspr(48, 42, 1, 3, 22, bgyoff + 10, 85, 3)
  sspr(47, 42, 1, 3, 107, bgyoff + 10)
end

--delete palidx if unused
function drawcol(x)
  drawchain(x)
  --bottom
  sspr(27, 32, 22, 14, x, bgyoff)
end

function drawchain(x)
  for i = 1, #lines, 2 do
    if i < 6 then
      pal(dark_pal[max(0, 3 - i // 2)])
    else
      pal()
    end
    palt(0x1000)
    local l = lines[i]
    local midx, midy = (l.pt1.x + l.pt2.x) / 2, (l.pt1.y + l.pt2.y) / 2
    local dx, dy = l.pt2.x - l.pt1.x, l.pt2.y - l.pt1.y
    local ang = 0.75 - atan2(dx, dy)
    pd_rotate(midx + x, midy, ang, 1, 9, 2)
  end
  for i = 2, #lines, 2 do
    if i < 6 then
      pal(dark_pal[max(0, 3 - i // 2)])
    else
      pal()
    end
    palt(0x1000)
    local l = lines[i]
    local midx, midy = (l.pt1.x + l.pt2.x) / 2, (l.pt1.y + l.pt2.y) / 2
    local dx, dy = l.pt2.x - l.pt1.x, l.pt2.y - l.pt1.y
    local ang = 0.75 - atan2(dx, dy)
    pd_rotate(midx + x, midy, ang, 3.5, 8.5, 1)
  end
end

function drawbtns()
  for i = 1, 4 do
    drawbtn(bgyoff + i * 20 + 24 - 115, curmenu[i].label, curmenu[i].offset, i == selmnu and 10 or 9)
  end
end

function drawbtn(y, lbl, xoff, col)
  sspr(0, 32, 13, 18, 20, y)
  sspr(13, 32, 1, 18, 33, y, 61, 18)
  sspr(13, 32, 14, 18, 94, y)
  print("\14" .. lbl, 50 + xoff, y + 7, col)
  print("\15")
end

function createchainskel()
  points, lines = {}, {}
  local a, lx, ly, sx, y, l = 0.250, 10, 20, 10, 10, 6
  local p1 = addpoint(lx, ly, sx, y)
  for i = 1, 18 do
    lx, ly, a, y = lx + cos(a) * l, ly + abs(sin(a)) * l, a + 0.125, y + l
    addpoint(lx, ly, sx, y)
  end
  for i = 1, #points - 1 do
    addline(points[i], points[i + 1])
  end
end

function addpoint(x1, y1, x2, y2)
  add(points, {x = x1, y = y1, x1 = x1, y1 = y1, x2 = x2, y2 = y2})
  return points[#points]
end

function addline(pt1, pt2)
  add(lines, {pt1 = pt1, pt2 = pt2})
  return lines[#lines - 1]
end

function movepoints(easeval)
  bgyoff = 0
  for p in all(points) do
    movepoint(p, easeval)
    bgyoff = p.y - 3
  end
end

function movepoint(p, easeval)
  local tt = mid(0, 1 - easeoutbounce(easeval), 1)
  p.x, p.y = lerp(p.x1, p.x2, tt), lerp(p.y1, p.y2, tt)
end

--menu scene
function updcred()
  --anim transition
  if hidescn then
    --  ease=(30-t)/30
    --  movepoints(ease)
    --  if (t==30) then 
    hidescn, showscn, t, curscene, nextscn = false, true, 0, nextscn, nil
  --  end
  elseif showscn then
    --  ease=t/30
    --  movepoints(ease)
    --  if (t==30) then
    showscn = false
  --  end
  else
    --[[
  if btn(5) or 
   mbtn1 and mbclick() then
   _ENV[curmenu[selmnu].action]()
   if (selmnu!=2) sfx(4)
  end
  ]]
    --
    if (btn(4) or mbtn2) or yt > #credtxt * 10 + 140 then
      hidescn, t, nextscn = true, 0, menuscn
    end
    if mb & 1 ~= 1 then
      yt += 1
    end
    if t % 3 == 0 then
      add_ash_part()
    end
  end
end

function drwcred()
  for k, txt in pairs(credtxt) do
    local y = 127 + k * 10 - yt
    local col = 12
    if y < 48 then
      col = 13
    end
    if y < 28 then
      col = 5
    end
    print(txt, 8, y + 1, 1)
    print(txt, 7, y, col)
  end
  --title
  sspr(0, 0, 109, 31, 8, 6)
  --mouse
  palt(0x1000)
  spr(14, mx, my)
end

function updrun()
  ttlpalidx = fadeoutidx()
  if t > 40 then
    --prepare game gfx
    lvl = selmnu
    unpack_map()
    --start game
    load "#picocraft_data_1-3"
    load "picocraft_data.p8"
  end
end

function drwrun()
  --?ttlpalidx.." "..t
  if t < 15 then
    --chains
    drawbg()
    drawcols()
    drawbtns()
    --title
    sspr(0, 0, 109, 31, 8, 6)
  end
  pal(dark_pal[ttlpalidx], 1)
end

