function goselectmap()
  nextmenu, hidescn, t = menu_map, true, 0
end

function launch()
  curscene, t = runscn, 0
end

function options()
  extcmd("pause")
end

function creds()
  hidescn, t, yt, nextscn = true, 0, 0, credscn
end

function exit()
  cls()
  print("thanks for playing picocraft")
  print("from @brullov_art @yourykiki")
  extcmd("shutdown")
end


