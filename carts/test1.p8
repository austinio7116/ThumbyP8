pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
-- ThumbyP8 phase 1+2 test cart
-- exercises: cls, rectfill, circfill, line, spr, map, btn,
-- camera, color, palette, the table helpers, sin/cos, fget.
--
-- NOTE: must be valid Lua 5.4 — the PICO-8 dialect rewriter
-- doesn't land until phase 3, so no `+=`, no `if(c)stmt`,
-- no `!=`, etc.

t = 0
px = 64
py = 64
particles = {}

function _init()
  srand(1)
  for i = 1, 30 do
    add(particles, {
      x = rnd(128),
      y = rnd(128),
      vx = (rnd(2) - 1) * 0.5,
      vy = (rnd(2) - 1) * 0.5,
      c = flr(rnd(15)) + 1
    })
  end
end

function _update()
  t = t + 1
  if btn(0) then px = px - 1 end
  if btn(1) then px = px + 1 end
  if btn(2) then py = py - 1 end
  if btn(3) then py = py + 1 end

  for p in all(particles) do
    p.x = p.x + p.vx
    p.y = p.y + p.vy
    if p.x < 0 then p.x = 128 end
    if p.x > 128 then p.x = 0 end
    if p.y < 0 then p.y = 128 end
    if p.y > 128 then p.y = 0 end
  end
end

-- Polyfill: PICO-8 ships `all()` for ipairs-style iteration; we
-- need to provide it ourselves until the dialect layer lands.
function all(t)
  local i = 0
  return function()
    i = i + 1
    if t[i] then return t[i] end
  end
end

function _draw()
  cls(1)

  -- starfield-ish background using particles
  for p in all(particles) do
    pset(p.x, p.y, p.c)
  end

  -- map: render the upper 16 tiles in the top-left
  map(0, 0, 0, 0, 16, 4)

  -- moving line spiral
  for i = 0, 11 do
    local a = (t / 60 + i / 12) % 1
    local x1 = 64 + cos(a) * 30
    local y1 = 64 + sin(a) * 30
    line(64, 64, x1, y1, 8 + (i % 8))
  end

  -- circle pulse
  local r = 8 + flr((sin(t / 30) + 1) * 6)
  circ(64, 64, r, 7)
  circfill(64, 64, 2, 10)

  -- player sprite (sprite 1) — drawn from gfx data we set below
  spr(1, px - 4, py - 4)

  -- HUD bar
  rectfill(0, 0, 127, 7, 0)
  rect(0, 0, 127, 7, 6)

  -- pixel position readout via palette colors
  pset(2, 3, 7)
  pset(4, 3, (px % 16))
  pset(6, 3, (py % 16))
end
